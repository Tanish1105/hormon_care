# Local MySQL (XAMPP/MAMP)
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=password
# DB_NAME=hormon

# Hostinger production deploy settings (hPanel → Deployments → Settings):
# - Install: npm ci
# - Build: npm run build
# - Start: node server.mjs   (or: npm run start)
# - Node.js: 20
# - Root directory: (empty)
# - Output directory: .next
# hPanel → Websites → hormoncare.mediiqr.com → Environment variables
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=u894177717_hormoncare
# DB_PASSWORD=your_password_here
# DB_NAME=u894177717_hormoncare_db
# JWT_SECRET=change-this-to-a-long-random-string

# Hostinger remote MySQL (local dev from your Mac only)
# 1. hPanel → Databases → Remote MySQL → add your public IP
# 2. Use hostname from Remote MySQL page (e.g. auth-db1825.hstgr.io)
# DB_HOST=auth-db1825.hstgr.io
# DB_PORT=3306
# DB_USER=u894177717_hormoncare
# DB_PASSWORD=your_password_here
# DB_NAME=u894177717_hormoncare_db

# Alternative: single connection string (encode @ in password as %40)
# DATABASE_URL=mysql://user:pass%40123@localhost:3306/dbname

# Optional: DB pool size (default 3 on Hostinger shared plans)
# DATABASE_POOL_SIZE=3

# Public site URL used in assessment / followup share links (WhatsApp, SMS, etc.)
# NEXT_PUBLIC_APP_URL=https://hormoncare.mediiqr.com


# Local MySQL (XAMPP/MAMP)
# DATABASE_URL="mysql://root:password@localhost:3306/hormon"

# Hostinger remote MySQL (local dev/testing)
# 1. hPanel → Databases → Remote MySQL → add your public IP → select database → Create
# 2. Hostname is shown at top of Remote MySQL page (e.g. auth-db1825.hstgr.io)
# DATABASE_URL="mysql://u894177717_DB_USER:DB_PASSWORD@auth-db1825.hstgr.io:3306/u894177717_hormoncare_db"

# Optional: DB pool size (default 2). Keep low on Hostinger remote MySQL.
# DATABASE_POOL_SIZE=2

# Hostinger production (app hosted on same server — use localhost)
# DATABASE_URL="mysql://u894177717_DB_USER:DB_PASSWORD@localhost:3306/u894177717_hormoncare_db"

JWT_SECRET="change-this-to-a-long-random-string"

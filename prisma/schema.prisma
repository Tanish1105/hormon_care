generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  role      String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patientProfile PatientProfile?
}

model PatientProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  requirements String? @db.Text
  planId       String?
  plan         Plan?    @relation(fields: [planId], references: [id])
  garbhaPlanId String?
  garbhaPlan   GarbhaPlan? @relation(fields: [garbhaPlanId], references: [id])
  childGuidancePlanId String?
  childGuidancePlan   ChildGuidancePlan? @relation(fields: [childGuidancePlanId], references: [id])
  startDate    DateTime @default(now())
  currentWeek  Int      @default(1)
  followupAccessToken String? @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  weeklyFollowups WeeklyFollowup[]
  lifestyleAssessment LifestyleAssessment?
}

model LifestyleAssessment {
  id               String   @id @default(cuid())
  patientProfileId String   @unique
  patientProfile   PatientProfile @relation(fields: [patientProfileId], references: [id], onDelete: Cascade)
  requestedAt      DateTime?
  submittedAt      DateTime?

  exerciseFrequency String?
  exerciseDuration  String?
  exerciseType      String?

  heightCm Float?
  weightKg Float?
  bmi      Float?

  sleepHours   String?
  sleepQuality String?
  nightShift   String?

  stressQ1 Int?
  stressQ2 Int?
  stressQ3 Int?
  stressQ4 Int?
  stressQ5 Int?
  stressScreeningScore Int?
  stressLevel  String?
  stressReason String? @db.Text

  dietType    String?
  breakfast   String?
  fastFood    String?
  waterIntake String?

  teaCoffee  String?
  coldDrinks String?
  sugarItems String?

  knownConditions String? @db.Text
  irregularMenses String? @db.Text
  supplements     String? @db.Text

  motherFamilyHistory String? @db.Text
  fatherFamilyHistory String? @db.Text

  partnerSmoking  String?
  partnerAlcohol  String?
  partnerExercise String?

  lifestyleScore       Int?
  doctorRecommendation String? @db.Text

  accessToken String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AppSetting {
  id                 String  @id @default("default")
  followupCompulsory Boolean @default(true)
}

model WeeklyFollowup {
  id                    String   @id @default(cuid())
  patientProfileId      String
  patientProfile        PatientProfile @relation(fields: [patientProfileId], references: [id], onDelete: Cascade)
  weekNumber            Int
  currentWeight         Float
  exerciseDays          Int
  lowWaterDays          Int
  shortSleepDays        Int
  missedSupplementDays  Int
  mealsDeviated         String? @db.Text
  planFeedback          String?
  feedbackLikedNotes    String? @db.Text
  feedbackDislikedNotes String? @db.Text
  feedbackBadNotes      String? @db.Text
  feedbackGoodNotes     String? @db.Text
  waist                 Float?
  chest                 Float?
  thigh                 Float?
  hip                   Float?
  arm                   Float?
  neck                  Float?
  consentAgreed         Boolean  @default(true)
  submittedAt           DateTime @default(now())

  @@unique([patientProfileId, weekNumber])
}

model Plan {
  id          String   @id @default(cuid())
  title       String
  description String? @db.Text
  imageUrl    String? @db.Text
  videoUrl    String? @db.Text
  totalWeeks  Int
  isCustom    Boolean  @default(false)
  isDayWise   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  weeks    PlanWeek[]
  patients PatientProfile[]
}

model PlanWeek {
  id          String   @id @default(cuid())
  planId      String
  plan        Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  weekNumber  Int
  title       String
  description String? @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contents WeekContent[]
  days     PlanDay[]

  @@unique([planId, weekNumber])
}

model PlanDay {
  id          String   @id @default(cuid())
  weekId      String
  week        PlanWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)
  dayNumber   Int
  title       String
  description String? @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contents DayContent[]

  @@unique([weekId, dayNumber])
}

model DayContent {
  id          String   @id @default(cuid())
  dayId       String
  day         PlanDay  @relation(fields: [dayId], references: [id], onDelete: Cascade)
  type        String
  title       String
  description String? @db.Text
  url         String? @db.Text
  content     String? @db.Text
  imageUrl    String? @db.Text
  videoUrl    String? @db.Text
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WeekContent {
  id          String   @id @default(cuid())
  weekId      String
  week        PlanWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)
  type        String
  title       String
  description String? @db.Text
  url         String? @db.Text
  content     String? @db.Text
  imageUrl    String? @db.Text
  videoUrl    String? @db.Text
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GarbhaPlan {
  id          String   @id @default(cuid())
  title       String
  description String? @db.Text
  imageUrl    String? @db.Text
  videoUrl    String? @db.Text
  totalWeeks  Int
  isDayWise   Boolean  @default(false)
  isCustom    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  weeks    GarbhaWeek[]
  patients PatientProfile[]
}

model GarbhaWeek {
  id          String   @id @default(cuid())
  planId      String
  plan        GarbhaPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  weekNumber  Int
  title       String
  description String? @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contents GarbhaContent[]
  days     GarbhaDay[]

  @@unique([planId, weekNumber])
}

model GarbhaDay {
  id          String     @id @default(cuid())
  weekId      String
  week        GarbhaWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)
  dayNumber   Int
  title       String
  description String? @db.Text
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  contents GarbhaDayContent[]

  @@unique([weekId, dayNumber])
}

model GarbhaDayContent {
  id          String    @id @default(cuid())
  dayId       String
  day         GarbhaDay @relation(fields: [dayId], references: [id], onDelete: Cascade)
  type        String
  title       String
  description String? @db.Text
  url         String? @db.Text
  content     String? @db.Text
  imageUrl    String? @db.Text
  videoUrl    String? @db.Text
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model GarbhaContent {
  id          String   @id @default(cuid())
  weekId      String
  week        GarbhaWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)
  type        String
  title       String
  description String? @db.Text
  url         String? @db.Text
  content     String? @db.Text
  imageUrl    String? @db.Text
  videoUrl    String? @db.Text
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ChildGuidancePlan {
  id          String   @id @default(cuid())
  title       String
  description String? @db.Text
  imageUrl    String? @db.Text
  videoUrl    String? @db.Text
  totalWeeks  Int
  isDayWise   Boolean  @default(false)
  isCustom    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  weeks    ChildGuidanceWeek[]
  patients PatientProfile[]
}

model ChildGuidanceWeek {
  id          String   @id @default(cuid())
  planId      String
  plan        ChildGuidancePlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  weekNumber  Int
  title       String
  description String? @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contents ChildGuidanceContent[]
  days     ChildGuidanceDay[]

  @@unique([planId, weekNumber])
}

model ChildGuidanceDay {
  id          String   @id @default(cuid())
  weekId      String
  week        ChildGuidanceWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)
  dayNumber   Int
  title       String
  description String? @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contents ChildGuidanceDayContent[]

  @@unique([weekId, dayNumber])
}

model ChildGuidanceDayContent {
  id          String   @id @default(cuid())
  dayId       String
  day         ChildGuidanceDay @relation(fields: [dayId], references: [id], onDelete: Cascade)
  type        String
  title       String
  description String? @db.Text
  url         String? @db.Text
  content     String? @db.Text
  imageUrl    String? @db.Text
  videoUrl    String? @db.Text
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ChildGuidanceContent {
  id          String   @id @default(cuid())
  weekId      String
  week        ChildGuidanceWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)
  type        String
  title       String
  description String? @db.Text
  url         String? @db.Text
  content     String? @db.Text
  imageUrl    String? @db.Text
  videoUrl    String? @db.Text
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
